      "Bash(sort:*)",
      "Bash(du:*)",
      "Bash(file:*)",
      "Bash(xargs cat:*)",
      "Bash(xargs -I:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(bash /tmp/*)",
      "Bash(python3:*)",
      "Bash(npx ng:*)",
      "Bash(npx tsc:*)",
      "Bash(npx cypress:*)",
      "Bash(npm uninstall:*)",
      "Bash(git -C:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
